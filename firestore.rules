rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // All reads and writes go through the backend (Admin SDK, which
    // bypasses these rules) — the client SDK is never used against
    // Firestore directly, so nothing here should ever be allowed.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
