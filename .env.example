# Backend: GCP project that hosts Firestore
FIREBASE_PROJECT_ID=safesurf-learn

# Backend: admin allowlist for the curation UI (comma-separated emails)
ADMIN_EMAILS=verablockeducators@gmail.com

# Backend: YouTube Data API sync
YOUTUBE_API_KEY=
YOUTUBE_CHANNEL_ID=UCleKAbI6ojw3A-dKSNChcqw

# Backend: Gemini API key (Google AI Studio, free tier), used to auto-generate practice quizzes for new lessons
GEMINI_API_KEY=

# Backend: Instagram Graph API (Instagram Login, Standard Access — no App Review
# needed for posting to VeraBlock's own account). Optional: if unset, new lessons
# just skip the Instagram post instead of failing. See INSTAGRAM_SETUP.md.
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=

# Frontend: Firebase web config (public, safe to bake into the build)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
